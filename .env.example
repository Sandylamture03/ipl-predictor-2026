# Database
DATABASE_URL=postgres://ipl_user:ipl_pass_2026@127.0.0.1:5432/ipl_predictor

# API server
PORT=3001
NODE_ENV=development

# CORS
# Comma-separated list. Supports wildcard patterns like https://*.example.com
CORS_ORIGINS=http://localhost:5173
WEB_URL=http://localhost:5173

# ML service URL used by API
ML_SERVICE_URL=http://127.0.0.1:8000

# Auto-train pre-match model on ML startup when artifact is missing (1=yes, 0=no)
AUTO_TRAIN_PREMATCH=1

# Cricket API
CRICKET_API_KEY=your_cricket_api_key_here
CRICKET_API_URL=https://api.cricapi.com/v1
IPL_SEASON=2026

# Optional legacy live API values (if used by custom integrations)
ROANUZ_API_KEY=your_roanuz_api_key_here
ROANUZ_BASE_URL=https://cricket.roanuz.com/v5/cricket

# Frontend
VITE_API_URL=http://localhost:3001

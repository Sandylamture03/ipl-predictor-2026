{
  "name": "ipl-predictor-api",
  "version": "1.0.0",
  "description": "IPL 2026 Win Predictor — Node/Express API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "ts-node src/db/migrate.ts",
    "import": "node ..\\..\\scripts\\import_cricsheet.js ..\\..\\data\\cricsheet",
    "forms": "node ..\\..\\scripts\\build_form_snapshots.js ..\\..\\data\\cricsheet",
    "fixtures": "node ..\\..\\scripts\\sync_ipl_2026_fixtures.js"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.5",
    "redis": "^4.6.14"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
